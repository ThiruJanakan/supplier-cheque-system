# Server
PORT=4000
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=12h

# Default admin (created on first migration)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_PHONE=+94771234567

# SMS gateway: "console" (logs to terminal, for dev) or "http" (generic HTTP gateway e.g. Twilio-compatible)
SMS_PROVIDER=console
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=CHQ-ALERT

# Daily scheduler time (24h, server local time) for due-date checks
ALERT_CRON=0 8 * * *
# Daily database backup time
BACKUP_CRON=0 2 * * *
BACKUP_KEEP=14
